# Öffentliche Supabase-Konfiguration
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SITE_URL=

# SMTP für Lead-Anfragen (nur serverseitig in Vercel setzen)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=info@tierischgutbetreut.de
SMTP_TO=info@tierischgutbetreut.de

# Resend (primärer E-Mail-Versand; SMTP als Fallback)
# Ersetze re_xxxxxxxxx durch deinen echten Resend-API-Key
RESEND_API_KEY=re_xxxxxxxxx
RESEND_FROM=info@tierischgutbetreut.de
RESEND_TEST_TO=dev@tigube.de
